<Window x:Class="POE_part2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:POE_part2"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>

        <!-- WELCOME SCREEN GRID -->
        <Grid x:Name="WelcomeGrid"
             >
            
            <Grid.Background>
                <ImageBrush ImageSource="/background.png"
                    Stretch="UniformToFill"/>
            </Grid.Background>

            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                

                <Image Source="/logo.png"
                       Width="450"
                       Height="200"
                       Margin="10"/>
                <Button Content="Start"
                        Width="150"
                        Height="40"
                        Click="Start_Click"
                        Background="#B0A9E5"/>
            </StackPanel>
        </Grid>


        <!-- NAME INPUT SCREEN GRID -->
        <Grid x:Name="NameGrid"
              Visibility="Collapsed">

            <Grid.Background>
                <ImageBrush ImageSource="/background.png"
         Stretch="UniformToFill"/>
            </Grid.Background>

            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                <TextBlock Text="Enter your name"
                       FontSize="24"
                       Margin="10"
                       HorizontalAlignment="Center"/>

                <TextBox x:Name="NameTextBox"
                     Width="250"
                     Height="35"
                     Margin="10"/>

                <TextBlock x:Name="ErrorText"
                       Foreground="Red"
                       Margin="5"
                       TextAlignment="Center"/>

                <Button Content="Submit"
                        Width="150"
                        Height="40"
                        Click="Submit_Click"
                        Background="#B0A9E5"/>

            </StackPanel>

        </Grid>


        <!-- CHAT SCREEN GRID -->
        <Grid x:Name="ChatGrid"
              Visibility="Collapsed">
            
            <Grid.Background>
                <ImageBrush ImageSource="/background.png"
         Stretch="UniformToFill"/>
            </Grid.Background>

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0"
                          VerticalScrollBarVisibility="Auto"
                          Margin="0,0,0,10"
                          HorizontalAlignment="Center"
                          Width="780"
                           Background="#7546E8">
                
                <RichTextBox x:Name="ChatListBox"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Background="#C8B3F6"
                         FontSize="14"/>
            </ScrollViewer>
            <ListView
                Height="300"
                Width="200"
                Margin="480,0,0,20"
                x:Name="chats"
                Background="#7546E8"
                />

            <StackPanel Orientation="Horizontal"
                        Grid.ColumnSpan="2"
                        Grid.Row="1"
                        Margin="10"
                        Background="#7546E8">

                

                <TextBox x:Name="MessageBox"
                         Width="650"
                         Height="35"
                         Margin="5"/>

                <Button Content="Send"
                        Width="100"
                        Height="35"
                        Click="Send_Click"
                        Background="#B0A9E5"/>

            </StackPanel>

        </Grid>
        
        
        
        

    </Grid>
</Window>
